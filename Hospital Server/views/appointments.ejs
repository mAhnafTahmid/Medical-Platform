<!-- appointments.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Appointments</title>
    <link rel="stylesheet" href="/style.css"> <!-- Link to your style.css file -->
</head>
<body>
    <div class="container">
        <header class="banner">
            <h1>Doctor Appointments</h1>
        </header>
        <main class="appointments">
            <ul class="appointment-list">
                <% appointments.forEach(appointment => { %>
                    <li class="appointment-card">
                        <div class="appointment-details">
                            <h2><%= appointment.doctor_name %></h2>
                            <p><strong>Patient:</strong> <%= appointment.name %></p>
                            <p><strong>Age:</strong> <%= appointment.age %></p>
                            <p><strong>Phone:</strong> <%= appointment.phone %></p>
                            <p><strong>Address:</strong> <%= appointment.address %></p>
                            <p><strong>Weight:</strong> <%= appointment.weight %> kg</p>
                            <p><strong>Appointment Time:</strong> <%= appointment.appointment_time.toLocaleString() %></p>
                        </div>
                    </li>
                <% }) %>
            </ul>
        </main>
    </div>
</body>
</html>
